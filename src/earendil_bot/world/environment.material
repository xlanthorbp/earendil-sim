vertex_program environment_vs glsl
{
    source environment.vert
}

fragment_program environment_fs glsl
{
    source environment.frag
}

material environment_material
{
    technique
    {
        pass
        {
            cull_hardware none
            cull_software none

            vertex_program_ref environment_vs
            {
            }
            fragment_program_ref environment_fs
            {
            }
        }
    }
}
