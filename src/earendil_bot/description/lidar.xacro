<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ============================================================ -->
<!-- RPLIDAR C1 DTOF                                              -->
<!-- Specs: 5kHz sample rate, 10Hz scan, 0.05-12m range, 15mm res -->
<!--        55.6 x 55.6 x 41.3 mm, 110g                          -->
<!-- ============================================================ -->

	<joint name="laser_joint" type="fixed">
		<parent link="body_link"/>
		<child link="laser_frame"/>
		<!-- Sits flush on top of body: body top is at z_dim/2 = 0.15, plus half lidar height -->
		<origin xyz="0 0 0.1707" rpy="0 0 0"/>
	</joint>

	<link name="laser_frame">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="0.0413" radius="0.0278"/>
        </geometry>
    </visual>

    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="0.0413" radius="0.0278"/>
        </geometry>
    </collision>

    <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="0.110"/>
        <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00001"/>
    </inertial>
</link>

<gazebo reference="laser_frame">
	<sensor name="laser" type="ray">
		<pose> 0 0 0 0 0 0 </pose>
		<visualize>true</visualize>
		<update_rate>10</update_rate>
		<ray>
			<scan>
				<horizontal>
					<samples>500</samples>
					<resolution>1</resolution>
					<min_angle>-${pi}</min_angle>
					<max_angle>${pi}</max_angle>
				</horizontal>
			</scan>
			<range>
				<min>0.7</min>
				<max>12.0</max>
				<resolution>0.015</resolution>
			</range>
		</ray>
		<plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
			<ros>
				<argument>~/out:=scan</argument>
			</ros>
			<output_type>sensor_msgs/LaserScan</output_type>
			<frame_name>laser_frame</frame_name>
		</plugin>
	</sensor>
</gazebo>

</robot>

